    {
      "parameters": {
        "functionCode": "const a = $input.first().json;\nconst d = new Date(a.start_time);\nconst fmtDate = d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long' });\nconst fmtTime = d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });\n\nconst reply = `✅ *Consulta cancelada*\\n\\n${a.specialty}\\n${fmtDate} às ${fmtTime}\\n\\nO horário foi liberado. Quando quiser, é só digitar *1* para agendar de novo. 😊`;\n\nreturn { json: { phone: a.phone, reply, success: true } };\n"
      },
      "id": "fn_c2",
      "name": "Monta confirmação de cancelamento",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1560, 300]
    },
