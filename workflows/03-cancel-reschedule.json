    {
      "parameters": {
        "functionCode": "const data = $json.body;\n\nconst SPECIALTIES = {\n  'clinico-geral': { duration: 30, calendarId: 'clinico-geral@clinica.com.br' },\n  'cardio':        { duration: 40, calendarId: 'cardio@clinica.com.br' },\n  'derma':         { duration: 30, calendarId: 'derma@clinica.com.br' },\n  'gineco':        { duration: 40, calendarId: 'gineco@clinica.com.br' },\n  'pediatra':      { duration: 30, calendarId: 'pediatra@clinica.com.br' },\n  'orto':          { duration: 40, calendarId: 'orto@clinica.com.br' }\n};\n\nconst [y, m, d] = data.newDate.split('-');\nconst [h, min] = data.newTime.split(':');\nconst start = new Date(Date.UTC(+y, +m - 1, +d, +h, +min));\nconst end = new Date(start.getTime() + 30 * 60 * 1000);\n\nreturn {\n  json: {\n    ...data,\n    newStartISO: start.toISOString(),\n    newEndISO: end.toISOString()\n  }\n};\n"
      },
