      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "typeValidation": "strict"},
          "conditions": [
            {"id": "c1", "leftValue": "={{ $json.body.action }}", "rightValue": "list", "operator": {"type": "string", "operation": "equals"}}
          ]
        }
      },
      "id": "if_c1",
      "name": "Ação = listar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 200]
    },
    {
      "parameters": {
        "functionCode": "const appts = $input.all().map(i => i.json);\nif (appts.length === 0) {\n  return { json: { reply: '📭 Você não tem consultas agendadas no momento.\\n\\nQuer *agendar* uma? Digite *1*.', success: true, count: 0 } };\n}\n\nlet list = '📅 *Suas próximas consultas:*\\n\\n';\nappts.forEach((a, i) => {\n  const d = new Date(a.start_time);\n  const fmtDate = d.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' });\n  const fmtTime = d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });\n  list += `*${i + 1}* — ${fmtDate} às ${fmtTime}\\n    ${a.specialty} (ID: ${a.id})\\n\\n`;\n});\n\nlist += '_Para cancelar, responda:_\\n*canc X* (onde X é o número)\\n\\n_Para remarcar:_\\n*remarca X novo-horário*';\n\nreturn { json: { reply: list, success: true, count: appts.length, appointments: appts } };\n"
      },
      "id": "fn_c1",
      "name": "Formata lista",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [900, 100]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
