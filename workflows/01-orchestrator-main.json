      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO patients (phone, name, created_at, updated_at) VALUES ('{{($json.phone || '').replace(/'/g, \"''\")}}', '{{($json.pushName || '').replace(/'/g, \"''\")}}', NOW(), NOW()) ON CONFLICT (phone) DO UPDATE SET name = COALESCE(EXCLUDED.name, patients.name), updated_at = NOW() RETURNING *;",
