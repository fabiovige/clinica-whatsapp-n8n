      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extrai campos do payload da Evolution API (webhook v2 encapsula em $json.body)\nconst body = $json.body || $json;\n\nconst remoteJid = body?.data?.key?.remoteJid || '';\nconst phone = remoteJid.replace('@s.whatsapp.net','').replace('@g.us','').replace('+','');\nconst msg = body?.data?.message || {};\n\nreturn {\n  event:     body.event || '',\n  instance:  body.instance || '',\n  phone:     phone,\n  fromMe:    body?.data?.key?.fromMe || false,\n  isGroup:   remoteJid.endsWith('@g.us'),\n  messageId: body?.data?.key?.id || '',\n  text:      msg.conversation || msg.extendedTextMessage?.text || msg.imageMessage?.caption || '',\n  pushName:  body?.data?.pushName || '',\n};"
      },
