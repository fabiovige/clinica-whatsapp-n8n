# ============================================================
# Clínica WhatsApp · Variáveis de ambiente
# Copie pra .env e preencha os valores reais
#   cp .env.example .env && nano .env
# ============================================================

# ------------ Infraestrutura ------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TroquePorUmaSenhaForte!2026
POSTGRES_DB=clinica
N8N_DB=n8n

# ------------ Domínio & HTTPS ------------
# Domínio público apontado pro seu servidor (DNS A record)
N8N_HOST=atendimento.clinicavida.com.br
N8N_PROTOCOL=https
WEBHOOK_URL=https://atendimento.clinicavida.com.br/
N8N_EDITOR_BASE_URL=https://atendimento.clinicavida.com.br/

# ------------ Evolution API (não-oficial) ------------
# Só preencha se for usar Evolution API
EVO_HOST=evolution
EVO_INSTANCE=clinica
# Gere uma chave aleatória: openssl rand -hex 32
EVO_APIKEY=

# ------------ Meta WhatsApp Cloud API (oficial) ------------
# Só preencha se for usar a API oficial da Meta
# Encontre em: https://developers.facebook.com/apps/ > WhatsApp > API Setup
META_PHONE_ID=
# Token permanente (gere em API Setup > Temporary access token OU configure System User)
META_TOKEN=
# Token que VOCÊ escolhe pra Meta verificar o webhook (qualquer string forte)
META_VERIFY_TOKEN=

# ------------ OpenAI (opcional, pra FAQ com IA) ------------
OPENAI_API_KEY=

# ------------ Execução n8n ------------
# regular (padrão) | queue (precisa Redis + workers)
EXECUTIONS_MODE=regular
